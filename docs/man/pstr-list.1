.SH NAME
pstr-list - Print a mailbox snapshot


.SH SYNOPSIS
\fBpstr list [flags]\fP


.SH DESCRIPTION
Print a mailbox snapshot to standard output without starting the interactive TUI.


.SH OPTIONS
\fB--account\fP=""
	filter by account name or email

.PP
\fB--format\fP="text"
	output format: text or json

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--label\fP=[]
	additional label filters

.PP
\fB--limit\fP=25
	maximum number of messages to list

.PP
\fB--mailbox\fP="inbox"
	mailbox to list: inbox, all, archive, drafts, sent, spam, trash, flagged

.PP
\fB--offset\fP=0
	number of messages to skip before listing


